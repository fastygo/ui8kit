package examples

import "github.com/fastygo/ui8kit/ui"

templ LayoutExample() {
	@ui.Box(ui.BoxProps{Tag: "section"}) {
		@ui.Container(ui.ContainerProps{}) {
			@ui.Stack(ui.StackProps{}) {
				@ui.Title(ui.TitleProps{Order: 2}, "Primitive layout")
				@ui.Text(ui.TextProps{}, "Use UI8Kit defaults first. Add variants or shared kit classes only when the default contract is not enough.")
			}
			@ui.Group(ui.GroupProps{}) {
				@ui.Button(ui.ButtonProps{Variant: "primary"}, "Primary action")
				@ui.Button(ui.ButtonProps{Variant: "outline"}, "Secondary action")
			}
		}
	}
}
