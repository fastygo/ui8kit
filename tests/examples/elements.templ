package examples

import (
	cmp "github.com/fastygo/ui8kit/components"
	"github.com/fastygo/ui8kit/ui"
)

templ ActionCardElement() {
	@cmp.Card(cmp.CardProps{Tag: "article"}) {
		@cmp.CardHeader(cmp.CardHeaderProps{}) {
			@cmp.CardTitle(cmp.CardTitleProps{Order: 3}, "Action card")
			@cmp.CardDescription(cmp.CardDescriptionProps{}, "A reusable element composed from Card, Text, Group, and Button without local classes.")
		}
		@cmp.CardContent(cmp.CardContentProps{}) {
			@ui.Group(ui.GroupProps{}) {
				@ui.Button(ui.ButtonProps{Variant: "primary"}, "Continue")
				@ui.Button(ui.ButtonProps{Variant: "outline"}, "Details")
			}
		}
	}
}

templ FormFieldElement() {
	@cmp.Card(cmp.CardProps{Variant: "muted", Tag: "article"}) {
		@cmp.CardHeader(cmp.CardHeaderProps{}) {
			@cmp.CardTitle(cmp.CardTitleProps{Order: 3}, "Form field")
			@cmp.CardDescription(cmp.CardDescriptionProps{}, "Field owns the label, hint, error, control, and ARIA wrapper contract.")
		}
		@cmp.CardContent(cmp.CardContentProps{}) {
			@ui.Field(ui.FieldProps{
				ID: "example-email",
				Name: "email",
				Type: "email",
				Label: "Email",
				Hint: "Used for product updates.",
				Placeholder: "name@example.com",
			})
		}
	}
}

templ DisclosureElement() {
	@cmp.Accordion(cmp.AccordionProps{}) {
		@cmp.AccordionItem(cmp.AccordionItemProps{Value: "shipping"}) {
			@cmp.AccordionTrigger(cmp.AccordionTriggerProps{Value: "shipping"}) {
				Shipping details
			}
			@cmp.AccordionContent(cmp.AccordionContentProps{Value: "shipping"}) {
				@ui.Text(ui.TextProps{}, "Accordion elements keep APG ids, controls, labels, and states wired through UI8Kit components.")
			}
		}
	}
}

templ DataTableElement() {
	@ui.Table(ui.TableProps{}) {
		@ui.TableCaption(ui.TableCaptionProps{}) {
			Plan limits
		}
		@ui.TableHead(ui.TableSectionProps{}) {
			@ui.TableRow(ui.TableRowProps{}) {
				@ui.TableHeadCell(ui.TableCellProps{Scope: "col"}) {
					Plan
				}
				@ui.TableHeadCell(ui.TableCellProps{Scope: "col"}) {
					Seats
				}
			}
		}
		@ui.TableBody(ui.TableSectionProps{}) {
			@ui.TableRow(ui.TableRowProps{}) {
				@ui.TableHeadCell(ui.TableCellProps{Scope: "row"}) {
					Starter
				}
				@ui.TableCell(ui.TableCellProps{}) {
					5
				}
			}
		}
	}
}

templ DescriptionListElement() {
	@ui.DescriptionList(ui.DescriptionListProps{}) {
		@ui.DescriptionTerm(ui.DescriptionTermProps{}) {
			Status
		}
		@ui.DescriptionDetails(ui.DescriptionDetailsProps{}) {
			Ready
		}
	}
}

templ NativeDisclosureElement() {
	@ui.Disclosure(ui.DisclosureProps{}) {
		@ui.DisclosureSummary(ui.DisclosureSummaryProps{}) {
			Native disclosure
		}
		@ui.Text(ui.TextProps{}, "Use this zero-JS primitive when APG accordion behavior is not required.")
	}
}

templ MediaElement() {
	@ui.Figure(ui.FigureProps{}) {
		@ui.Picture(ui.PictureProps{}) {
			@ui.Source(ui.SourceProps{SrcSet: "/static/example.avif", Type: "image/avif"})
			@ui.Image(ui.ImageProps{Src: "/static/example.png", Alt: "Example preview", Aspect: "video"})
		}
		@ui.FigureCaption(ui.FigureCaptionProps{}) {
			Responsive media with a semantic caption.
		}
	}
}

templ FormElement() {
	@ui.Form(ui.FormProps{Method: "post"}) {
		@ui.Fieldset(ui.FieldsetProps{}) {
			@ui.Legend(ui.LegendProps{}) {
				Account
			}
			@ui.Field(ui.FieldProps{Name: "email", Type: "email", Label: "Email"})
		}
	}
}
